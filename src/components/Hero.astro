---
export interface Props {
  heading: string;
  subheading?: string;
}

const { heading, subheading } = Astro.props as Props;
---

{
  heading && (
    <section class="border-b">
      <div class="container py-16 text-center sm:py-24">
        <h1 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
          {heading}
        </h1>
        {subheading && (
          <p class="mx-auto mt-4 max-w-2xl text-base text-gray-600 sm:text-lg">
            {subheading}
          </p>
        )}
      </div>
    </section>
  )
}
