PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_MEDUSA_REGION_ID=reg_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional. When set, checkout offers Stripe (provider `pp_stripe_stripe`,
# configured on the Medusa backend) instead of the manual payment provider,
# and the Stripe client SDK is loaded on the payment step.
PUBLIC_STRIPE_KEY=

# Optional. Store name shown in the header, page titles, and footer.
# Defaults to "Your Store" when unset.
PUBLIC_STORE_NAME=

# Optional. Announcement banner message shown above the header. The banner
# is hidden entirely when this is unset/empty.
PUBLIC_ANNOUNCEMENT_MESSAGE=
